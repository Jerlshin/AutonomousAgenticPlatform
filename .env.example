# System Runtime Modes
ENVIRONMENT=development
PROJECT_NAME=autonomous-ai-platform

# Database Routing & Engine Parameters
DATABASE_URL=postgresql://ai_user:ai_password@localhost:5432/platform_db

# Asynchronous Message Brokers & State Engines
REDIS_URL=redis://localhost:6379/0

# Dense Multi-Dimensional Vector Engine Maps
QDRANT_HOST=localhost
QDRANT_PORT=6333

# MLOps Experiment Tracking Services
MLFLOW_TRACKING_URI=http://localhost:5000

# Accelerated Inference Local Host Execution Hooks
# Mac native localhost interface addressed from within docker environments
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Agent Execution Sandbox
SANDBOX_TIMEOUT_SECONDS=20
USE_DOCKER_SANDBOX=false
SANDBOX_IMAGE=autonomous-ai-sandbox:latest
MAX_AGENT_RETRIES=2

# Local model routing
PLANNER_MODEL=llama3.1:8b
RESEARCHER_MODEL=llama3.1:8b
CODER_MODEL=qwen2.5-coder:3b
DEBUGGER_MODEL=qwen2.5-coder:3b
EVALUATOR_MODEL=llama3.1:8b
